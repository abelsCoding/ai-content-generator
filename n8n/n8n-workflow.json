    {
      "parameters": {
        "jsCode": "const product = $json.product;\n\nreturn [\n  {\n    json: {\n      product,\n      content: `\n### Version 1 — Professional\nA high-quality ${product} designed for performance and reliability.\n\n### Version 2 — Casual\nLooking for a solid ${product}? This one gets the job done.\n\n### Version 3 — Persuasive\nDon't miss out on this amazing ${product} — upgrade your experience today!\n`\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "7ba89614-59b7-457c-85d7-4477ca906237",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const product = $json.product;\nconst content = $json.content;\n\nconst markdown = `\n# ${product}\n\n${content}\n\n---\nGenerated on: ${new Date().toISOString()}\n`;\n\nreturn [\n  {\n    json: {\n      fileName: product.toLowerCase().replace(/\\s+/g, \"-\") + \".md\",\n      markdown: markdown\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
