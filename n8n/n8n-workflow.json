      "name": "Read/Write Files from Disk"
    },
    {
      "parameters": {
        "jsCode": "const content = $json.markdown;\n\nreturn [\n  {\n    json: {\n      fileName: $json.fileName\n    },\n    binary: {\n      data: {\n        data: Buffer.from(content).toString('base64'),\n        mimeType: 'text/markdown',\n        fileName: $json.fileName,\n      }\n    }\n  }\n];"
      },
